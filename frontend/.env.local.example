# Variabili d'ambiente per il FRONTEND Next.js.
# Copia questo file come .env.local e compila i valori.

# Supabase (chiavi pubbliche, safe per il browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
